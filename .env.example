# AI Provider Keys
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=openai/gpt-4-turbo
# QDRANT_URL=http://localhost:6333 # Use "local" to store vectors in backend/data/qdrant_local
QDRANT_URL=local
# QDRANT_API_KEY=your_qdrant_key

# Database (PostgreSQL or SQLite for local dev)
# DATABASE_URL=postgresql://user:pass@localhost:5432/receptionist
DATABASE_URL=sqlite:///./receptionist.db

# App Settings
APP_NAME="AI Voice Receptionist"
DEBUG=true

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=3
SIMILARITY_THRESHOLD=0.7

# TTS/STT Settings
WHISPER_MODEL=base
TTS_PROMPT="A professional and friendly receptionist voice."
